# ============================================================================
# Environment Configuration for Kuti Studio Backend v2
# ============================================================================

# ----------------------------------------------------------------------------
# Core Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=8000

# Comma-separated list of allowed origins for CORS
TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Application info (optional, defaults are provided)
APP_NAME=Kuti Studio Backend

# ----------------------------------------------------------------------------
# Data Directory (Stockage local)
# ----------------------------------------------------------------------------
# Chemin absolu ou relatif vers le dossier de données
KUTI_DATA_DIR=./kuti-data

# ----------------------------------------------------------------------------
# Database (PostgreSQL requis)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/kuti_studio

# ----------------------------------------------------------------------------
# Better Auth (optionnel - auth non activée dans v2 initiale)
# ----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:8000
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here

# ----------------------------------------------------------------------------
# Redis (optionnel - pour Inngest et caching)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Inngest (pour les jobs asynchrones: génération d'images, exports)
# ----------------------------------------------------------------------------
# Pour dev local avec Inngest Dev Server: pas besoin de clés
# Pour prod: configurer avec vos clés Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ----------------------------------------------------------------------------
# Model Providers - GPT Images
# ----------------------------------------------------------------------------
GPT_IMAGES_1_5_BASE_URL=https://api.openai.com/v1
GPT_IMAGES_1_5_API_KEY=sk-...
GPT_IMAGES_1_5_ENABLED=true

GPT_IMAGES_2_BASE_URL=https://api.openai.com/v1
GPT_IMAGES_2_API_KEY=sk-...
GPT_IMAGES_2_ENABLED=true

# ----------------------------------------------------------------------------
# Model Providers - Video Generation
# ----------------------------------------------------------------------------
SORA_2_BASE_URL=https://api.openai.com/v1
SORA_2_API_KEY=sk-...
SORA_2_ENABLED=true

SEEDANCE_2_BASE_URL=https://api.sea.tv/v1
SEEDANCE_2_API_KEY=...
SEEDANCE_2_ENABLED=true

# ----------------------------------------------------------------------------
# Model Providers - Audio (pas encore implémenté)
# ----------------------------------------------------------------------------
ELEVEN_LABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVEN_LABS_API_KEY=...
ELEVEN_LABS_ENABLED=false
